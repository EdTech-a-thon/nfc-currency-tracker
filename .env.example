# Local development database. The Docker stack overrides this with Postgres.
DATABASE_URL="file:./dev.db"
# Use at least 32 random characters. Example: openssl rand -base64 48
SESSION_SECRET="replace-with-a-long-random-secret"
# Permanent public origin encoded on cards. Finalize before writing any card.
CARD_BASE_URL="https://cards.example.com"
# Docker Postgres settings. Use a URL-safe random password.
POSTGRES_DB="nfc_currency"
POSTGRES_USER="nfc_currency"
POSTGRES_PASSWORD="replace-with-a-strong-random-password"
# Public hostname served by Caddy, without https://
DOMAIN="rewards.example.com"
